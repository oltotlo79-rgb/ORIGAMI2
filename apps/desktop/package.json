{
  "name": "@origami2/desktop",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "oxlint",
    "test": "npm run test:snap && npm run test:dom",
    "test:dom": "vitest run --config vitest.config.ts",
    "test:snap": "node --test \"tests/*.test.ts\"",
    "test:gltf-validator": "node scripts/validate-generated-glb.mjs",
    "test:gltf-sample-viewer": "node scripts/sample-viewer-runtime-e2e.mjs",
    "preview": "vite preview",
    "tauri": "tauri",
    "bundle:windows:ci": "tauri build --ci --no-sign --bundles nsis",
    "bundle:macos:ci": "tauri build --ci --no-sign --bundles app"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "three": "^0.185.1",
    "zustand": "^5.0.14"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^24.13.2",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^6.0.3",
    "gltf-validator": "2.0.0-dev.3.10",
    "jsdom": "^29.1.1",
    "oxlint": "^1.71.0",
    "playwright": "1.61.1",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vitest": "^4.1.10"
  }
}

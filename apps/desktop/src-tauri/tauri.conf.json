{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ORIGAMI2",
  "version": "0.1.0",
  "identifier": "dev.origami2.editor",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "ORIGAMI2", "width": 1440, "height": 900, "minWidth": 980, "minHeight": 680 }],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'; frame-src 'none'; worker-src 'none'; media-src 'none'; manifest-src 'none'; font-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost https://api.github.com"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": {
      "../../../crates/ori-formats/assets/fonts/NotoSansJP-Variable.ttf": "fonts/NotoSansJP-Variable.ttf",
      "../../../crates/ori-formats/assets/fonts/NotoSansJP-OFL.txt": "licenses/NotoSansJP-OFL.txt"
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}

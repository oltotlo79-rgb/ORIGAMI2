{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ORIGAMI2",
  "version": "0.1.0",
  "identifier": "dev.origami2.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [{ "title": "ORIGAMI2", "width": 1440, "height": 900, "minWidth": 980, "minHeight": 680 }],
    "security": {
      "csp": "default-src 'self'; img-src 'self' asset: data:; style-src 'self' 'unsafe-inline'; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": { "active": true, "targets": "all" }
}
